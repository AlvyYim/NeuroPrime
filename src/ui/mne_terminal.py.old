    'MNE Basic': MNE_ALGORITHM_TEMPLATE,
    'MNE ICA': MNE_ICA_TEMPLATE,
    'MNE Source Localization': MNE_SOURCE_LOCALIZATION_TEMPLATE,
    'MNE Filtering': MNE_FILTERING_TEMPLATE,
